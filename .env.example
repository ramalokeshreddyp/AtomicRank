# =========================================================
# Redis Game Leaderboard — Environment Configuration
# =========================================================
# Copy this file to .env and fill in real values before running.
# NEVER commit your actual .env file to source control.

# -----------------------------------------------------------
# Redis Connection
# -----------------------------------------------------------
# Connection string for the Redis server.
# When running with Docker Compose, use the service name "redis".
# When running locally against a standalone Redis, use localhost.
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------
# API Server
# -----------------------------------------------------------
# Port on which the API server will listen.
API_PORT=3000

# -----------------------------------------------------------
# Application Settings
# -----------------------------------------------------------
# Node environment (development | production | test)
NODE_ENV=production

# Session TTL in seconds (default: 1800 = 30 minutes)
SESSION_TTL=1800

# Points awarded for a correct quiz answer
CORRECT_ANSWER_POINTS=10
